---
/*
  NeuralNetwork.astro — Animated canvas background for the hero.

  HOW IT WORKS:
  - Draws a neural network visualization on a <canvas> element
  - Nodes pulse gently; connections light up when your mouse is nearby
  - A CSS gradient mask fades the network from transparent (left) to visible (right)
  - This is one of the few components that ships JavaScript to the browser,
    because the animation needs to run in real time.

  HOW TO MODIFY:
  - Change network shape: edit the LAYERS array (e.g. [3, 5, 5, 3] for fewer nodes)
  - Change colors: it reads --accent from CSS, so changing that variable changes the network color
  - Disable it: just remove <NeuralNetwork /> from Hero.astro
*/
---

<canvas
  id="nn-canvas"
  style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0;transition:opacity 0.8s ease;"
></canvas>

<script>
  const canvas = document.getElementById('nn-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // Network architecture: each number = nodes in that layer
  const LAYERS = [4, 6, 6, 4, 2];
  let nodes: { x: number; y: number; li: number; ni: number; pulse: number; activation: number }[] = [];
  let edges: { from: number; to: number; signal: number; t: number }[] = [];
  let mouse = { x: -9999, y: -9999 };
  let animFrame: number;
  let active = false;

  function buildNetwork() {
    nodes = [];
    edges = [];
    const W = canvas.offsetWidth;
    const H = canvas.offsetHeight;
    const layerCount = LAYERS.length;
    const xStep = W / (layerCount + 1);

    LAYERS.forEach((count, li) => {
      const x = xStep * (li + 1);
      const yStep = H / (count + 1);
      for (let ni = 0; ni < count; ni++) {
        nodes.push({
          x, y: yStep * (ni + 1),
          li, ni,
          pulse: Math.random() * Math.PI * 2,
          activation: 0,
        });
      }
    });

    // Connect each node to every node in the next layer
    for (let i = 0; i < nodes.length; i++) {
      for (let j = 0; j < nodes.length; j++) {
        if (nodes[j].li === nodes[i].li + 1) {
          edges.push({ from: i, to: j, signal: 0, t: Math.random() });
        }
      }
    }
  }

  // Parse the accent color from CSS variables
  let cachedAccent: string | null = null;
  let cachedRgb = [79, 122, 40]; // default green
  const lineWeight = 0.3 + (45 / 100) * 2.7; // matches tweak default of 45%

  function parseAccent() {
    const raw = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
    if (raw === cachedAccent) return;
    cachedAccent = raw;
    const tmp = document.createElement('div');
    tmp.style.color = raw;
    tmp.style.position = 'absolute';
    tmp.style.visibility = 'hidden';
    document.body.appendChild(tmp);
    const rgb = getComputedStyle(tmp).color;
    document.body.removeChild(tmp);
    const match = rgb.match(/\d+/g);
    if (match) cachedRgb = match.map(Number);
  }

  function resize() {
    applyRegion();
    canvas.width = canvas.offsetWidth || canvas.parentElement!.offsetWidth;
    canvas.height = canvas.offsetHeight || canvas.parentElement!.offsetHeight;
    buildNetwork();
  }

  // Region: position/size of the canvas within the hero
  const region = { x: 38, y: 50, w: 110, h: 100 };

  function applyRegion() {
    canvas.style.left = '50%';
    canvas.style.top = '50%';
    canvas.style.width = region.w + '%';
    canvas.style.height = region.h + '%';
    canvas.style.inset = 'unset';
    canvas.style.transform = `translate(calc(-50% + ${region.x}%), calc(-50% + ${region.y}%))`;
  }

  function setFade(pct: number) {
    const p1 = Math.max(0, pct - 23);
    const p2 = pct;
    const p3 = Math.min(100, pct + 20);
    const p4 = Math.min(100, pct + 34);
    const mask = `linear-gradient(to right, transparent 0%, transparent ${p1}%, rgba(0,0,0,0.3) ${p2}%, rgba(0,0,0,0.85) ${p3}%, black ${p4}%)`;
    canvas.style.webkitMaskImage = mask;
    canvas.style.maskImage = mask;
  }

  function draw(ts: number) {
    if (!active) return;
    animFrame = requestAnimationFrame(draw);
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    const t = ts * 0.001;
    parseAccent();
    const [ar, ag, ab] = cachedRgb;

    // Update node activations based on pulse + mouse proximity
    nodes.forEach(n => {
      const dx = n.x - mouse.x, dy = n.y - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const proximity = Math.max(0, 1 - dist / 180);
      n.activation = 0.25 + 0.15 * Math.sin(t * 0.6 + n.pulse) + proximity * 0.35;
      n.activation = Math.min(1, n.activation);
    });

    // Update edge signals
    edges.forEach(e => {
      e.t = (e.t + 0.0015 + nodes[e.from].activation * 0.002) % 1;
      e.signal = nodes[e.from].activation;
    });

    // Draw edges
    edges.forEach(e => {
      const fn = nodes[e.from], tn = nodes[e.to];
      const alpha = 0.05 + e.signal * 0.08;
      ctx.beginPath();
      ctx.moveTo(fn.x, fn.y);
      ctx.lineTo(tn.x, tn.y);
      ctx.strokeStyle = `rgba(${ar},${ag},${ab},${alpha})`;
      ctx.lineWidth = lineWeight;
      ctx.stroke();

      // Travelling signal dot
      if (e.t < 0.3) {
        const progress = e.t / 0.3;
        const sx = fn.x + (tn.x - fn.x) * progress;
        const sy = fn.y + (tn.y - fn.y) * progress;
        ctx.beginPath();
        ctx.arc(sx, sy, 1.2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${ar},${ag},${ab},${0.1 + e.signal * 0.2})`;
        ctx.fill();
      }
    });

    // Draw nodes
    nodes.forEach(n => {
      const r = 2.5 + n.activation * 2;
      const alpha = 0.1 + n.activation * 0.22;

      // Outer glow
      const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, r * 3);
      grad.addColorStop(0, `rgba(${ar},${ag},${ab},${alpha * 0.5})`);
      grad.addColorStop(1, `rgba(${ar},${ag},${ab},0)`);
      ctx.beginPath();
      ctx.arc(n.x, n.y, r * 3, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${ar},${ag},${ab},${0.15 + n.activation * 0.3})`;
      ctx.fill();
    });
  }

  function start() {
    if (active) return;
    active = true;
    canvas.style.opacity = '1';
    setFade(54); // fade-in point from tweaks default
    resize();
    animFrame = requestAnimationFrame(draw);
  }

  // Mouse tracking
  canvas.parentElement!.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  canvas.parentElement!.addEventListener('mouseleave', () => {
    mouse.x = -9999;
    mouse.y = -9999;
  });

  window.addEventListener('resize', () => { if (active) resize(); });

  // Auto-start
  start();
</script>
