---
/*
  BaseLayout.astro — The shared HTML shell for every page.

  HOW IT WORKS:
  - Every page imports this layout and wraps its content in it.
  - The <slot /> below is where each page's unique content goes.
  - The frontmatter block (between the --- lines) runs at BUILD TIME,
    not in the browser. It's where you accept props and do setup.

  PROPS:
  - title: the <title> tag for this page
  - description: the meta description for SEO
*/

import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const {
  title = 'Yannick den Boer — AI Engineer',
  description = 'AI Engineer, Teacher & Enthusiast. Training professionals in applied AI, prompt engineering, and Python.',
  hideFooter = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts: DM Sans (body), DM Mono (labels), Lora (headings) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Mono:wght@300;400;500&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- Each page's content gets inserted here -->
  <slot />

  {!hideFooter && <Footer />}

  <!-- Scroll reveal: makes sections fade in as you scroll down -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            observer.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
