---
/*
  index.astro — Your homepage.

  HOW THIS WORKS:
  - This file is at src/pages/index.astro → it becomes the "/" URL
  - It imports the BaseLayout (shared HTML shell) and all section components
  - The components are rendered in order inside the layout's <slot />
  - To add a new section, import its component and drop it in below

  HOW TO ADD A NEW PROJECT:
  - Add another <ProjectCard ... /> inside the projects-grid div
  - Update the project count in the section-count span
*/

import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TechStack from "../components/TechStack.astro";
import Contact from "../components/Contact.astro";
import thesisCover from "../assets/thesis-cover.png";

// SVG thumbnails for project cards
const trainingThumbSvg = `<svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect x="10" y="20" width="52" height="34" rx="5" stroke="#B0C0D4" stroke-width="1.2"/>
  <rect x="18" y="28" width="16" height="4" rx="2" fill="#C8D4E4" opacity="0.7"/>
  <rect x="18" y="36" width="26" height="4" rx="2" fill="#D4DCE8" opacity="0.6"/>
  <rect x="18" y="44" width="20" height="4" rx="2" fill="#D4DCE8" opacity="0.5"/>
  <circle cx="50" cy="28" r="8" fill="#8FAACC" opacity="0.4"/>
  <path d="M47 28 L49.5 30.5 L54 26" stroke="#6B9FD4" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;

const cvThumbSvg = `<svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect x="12" y="12" width="48" height="48" rx="6" stroke="#B0C0D4" stroke-width="1.2"/>
  <circle cx="36" cy="36" r="14" stroke="#8FAACC" stroke-width="1.2" stroke-dasharray="4 3"/>
  <circle cx="36" cy="36" r="5" fill="#6B9FD4" opacity="0.45"/>
  <line x1="36" y1="22" x2="36" y2="27" stroke="#B0C0D4" stroke-width="1"/>
  <line x1="36" y1="45" x2="36" y2="50" stroke="#B0C0D4" stroke-width="1"/>
  <line x1="22" y1="36" x2="27" y2="36" stroke="#B0C0D4" stroke-width="1"/>
  <line x1="45" y1="36" x2="50" y2="36" stroke="#B0C0D4" stroke-width="1"/>
</svg>`;
---

<BaseLayout>
  <Nav />
  <Hero />

  <!-- PROJECTS -->
  <section id="projects" class="section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-title">Selected work</span>
        <div class="section-rule"></div>
        <span class="section-count">03 projects</span>
      </div>

      <div class="projects-grid reveal">
        <ProjectCard
          featured={true}
          org="UMC Utrecht · Research"
          title="Thesis Dissertation"
          description="Designed and evaluated a pipeline to assess the feasibility of classifying behavioral cues in preterm infants using Vision-Language Models, supporting clinical assessment at UMC Utrecht."
          accentTag="Qwen-VL"
          tags={["PyTorch", "HuggingFace", "Research"]}
          href="/projects/thesis/"
          thumbImg={thesisCover.src}
          thumbAlt="Title page of MSc thesis: Cue Classification in Preterm Infants Using Vision-Language Models"
        />

        <ProjectCard
          org="CodeCafé"
          title="Applied AI & Python Training"
          description="Curriculum design and delivery for professionals learning applied AI, prompt engineering, and Python — hands-on, practical, results-driven."
          accentTag="Teaching"
          tags={["Python", "Prompt Eng."]}
          thumbSvg={trainingThumbSvg}
        />

        <ProjectCard
          org="Personal Project"
          title="Computer Vision & C# Tooling"
          description="Exploratory work combining OpenCV-based vision pipelines with C# tooling, applying learned techniques to real-world image processing problems."
          tags={["OpenCV", "C#", "NumPy"]}
          thumbSvg={cvThumbSvg}
        />
      </div>
    </div>
  </section>

  <TechStack />
  <Contact />
</BaseLayout>
